{
  "name": "@validance/safeclaw",
  "version": "0.1.10",
  "description": "Containerized execution for OpenClaw via Validance kernel",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "safeclaw": "bin/safeclaw.mjs"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "validance",
    "safeclaw",
    "security"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Wik-dev/safeclaw.git"
  },
  "files": [
    "dist/",
    "catalog/",
    "bin/",
    "openclaw.plugin.json"
  ],
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "@types/node": "^20.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ],
    "runtimeExtensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.4.15",
      "minGatewayVersion": "2026.4.15"
    },
    "build": {
      "openclawVersion": "2026.4.15"
    }
  }
}

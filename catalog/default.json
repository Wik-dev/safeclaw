{
  "templates": {
    "exec": {
      "persistent": true,
      "docker_image": "sandbox",
      "command_template": "python /project/scripts/exec.py",
      "parameter_schema": {
        "type": "object",
        "properties": {
          "command": {"type": "string", "description": "Shell command to execute"},
          "cwd": {"type": "string", "description": "Working directory (relative to /workspace)"},
          "env": {"type": "object", "description": "Environment variables to set"},
          "timeout": {"type": "number", "description": "Timeout in seconds"}
        },
        "required": ["command"]
      },
      "approval_tier": "human-confirm",
      "timeout": 120,
      "rate_limit": 200,
      "network_policy": null,
      "volumes": {
        "/workspace": {"host_path": "${WORKSPACE}", "mode": "rw"},
        "/home": {"host_path": "${HOME}", "mode": "ro"}
      }
    },
    "write": {
      "persistent": false,
      "docker_image": "sandbox",
      "command_template": "python /project/scripts/write_file.py",
      "parameter_schema": {
        "type": "object",
        "properties": {
          "path": {"type": "string", "description": "File path relative to workspace"},
          "content": {"type": "string", "description": "File content to write"}
        },
        "required": ["path", "content"]
      },
      "approval_tier": "auto-approve",
      "timeout": 30,
      "rate_limit": 500,
      "volumes": {
        "/workspace": {"host_path": "${WORKSPACE}", "mode": "rw"}
      }
    },
    "edit": {
      "persistent": false,
      "docker_image": "sandbox",
      "command_template": "python /project/scripts/edit_file.py",
      "parameter_schema": {
        "type": "object",
        "properties": {
          "path": {"type": "string", "description": "File path relative to workspace"},
          "old_string": {"type": "string", "description": "Text to find"},
          "new_string": {"type": "string", "description": "Text to replace with"}
        },
        "required": ["path", "old_string", "new_string"]
      },
      "approval_tier": "auto-approve",
      "timeout": 30,
      "rate_limit": 500,
      "volumes": {
        "/workspace": {"host_path": "${WORKSPACE}", "mode": "rw"}
      }
    },
    "apply_patch": {
      "persistent": false,
      "docker_image": "sandbox",
      "command_template": "python /project/scripts/apply_patch.py",
      "parameter_schema": {
        "type": "object",
        "properties": {
          "input": {"type": "string", "description": "Patch content using *** Begin Patch / *** End Patch format"}
        },
        "required": ["input"]
      },
      "approval_tier": "auto-approve",
      "timeout": 30,
      "rate_limit": 500,
      "volumes": {
        "/workspace": {"host_path": "${WORKSPACE}", "mode": "rw"}
      }
    },
    "browser": {
      "persistent": true,
      "docker_image": "browser",
      "command_template": "python /project/scripts/browser.py",
      "parameter_schema": {
        "type": "object",
        "properties": {
          "action": {"type": "string", "enum": ["snapshot", "navigate", "click", "type", "hover", "press", "select", "scroll", "screenshot", "evaluate", "console", "wait", "tabs", "open", "close", "focus", "pdf", "dialog", "upload", "submit_form", "read_text"]},
          "url": {"type": "string", "description": "URL for navigate/open"},
          "ref": {"type": "string", "description": "Element ref from snapshot (e.g. e1, e2)"},
          "selector": {"type": "string", "description": "CSS selector (alternative to ref)"},
          "text": {"type": "string", "description": "Text to type or wait for"},
          "key": {"type": "string", "description": "Keyboard key (e.g. Enter, Tab, ArrowDown)"},
          "script": {"type": "string", "description": "JavaScript to evaluate"},
          "direction": {"type": "string", "enum": ["up", "down"], "description": "Scroll direction"},
          "fullPage": {"type": "boolean", "description": "Full page screenshot"},
          "interactive": {"type": "boolean", "description": "Snapshot interactive elements only"},
          "depth": {"type": "number", "description": "Max snapshot tree depth"},
          "maxChars": {"type": "number", "description": "Max snapshot text length"},
          "index": {"type": "number", "description": "Tab index for focus/close"},
          "accept": {"type": "boolean", "description": "Accept or dismiss dialog"},
          "values": {"type": "array", "items": {"type": "string"}, "description": "Values for select dropdown"},
          "paths": {"type": "array", "items": {"type": "string"}, "description": "File paths for upload"},
          "submit": {"type": "boolean", "description": "Press Enter after typing"},
          "timeMs": {"type": "number", "description": "Milliseconds to wait"},
          "timeoutMs": {"type": "number", "description": "Action timeout in ms"},
          "loadState": {"type": "string", "description": "Wait for page state (load, domcontentloaded, networkidle)"},
          "subtype": {"type": "string", "description": "For policy ceiling checks"}
        },
        "required": ["action"]
      },
      "approval_tier": "human-confirm",
      "timeout": 3600,
      "rate_limit": 30,
      "volumes": {
        "/downloads": {"host_path": "${WORKSPACE}/downloads", "mode": "rw"}
      },
      "policy_ceilings": ["evaluate", "execute_js", "submit_form"]
    },
    "web_search": {
      "persistent": false,
      "docker_image": "web",
      "command_template": "python /project/scripts/web_search.py",
      "parameter_schema": {
        "type": "object",
        "properties": {
          "query": {"type": "string", "description": "Search query"},
          "count": {"type": "number", "description": "Number of results (1-10, default 5)"},
          "country": {"type": "string", "description": "2-letter country code (e.g. US, DE, FR)"},
          "language": {"type": "string", "description": "Language code (e.g. en, fr, de)"},
          "freshness": {"type": "string", "description": "Recency filter (d1=past day, w1=past week, m1=past month, y1=past year)"},
          "date_after": {"type": "string", "description": "Only results after this date (YYYY-MM-DD)"},
          "date_before": {"type": "string", "description": "Only results before this date (YYYY-MM-DD)"}
        },
        "required": ["query"]
      },
      "approval_tier": "auto-approve",
      "secret_refs": ["SEARCH_API_KEY"],
      "timeout": 30,
      "rate_limit": 100,
      "network_policy": {"egress_allow": ["api.search.brave.com:443"]}
    },
    "web_fetch": {
      "persistent": false,
      "docker_image": "web",
      "command_template": "python /project/scripts/web_fetch.py",
      "parameter_schema": {
        "type": "object",
        "properties": {
          "url": {"type": "string", "description": "URL to fetch"},
          "method": {"type": "string", "enum": ["GET", "POST"], "default": "GET"},
          "headers": {"type": "object", "description": "HTTP headers"},
          "body": {"type": "string", "description": "Request body"},
          "extractMode": {"type": "string", "enum": ["markdown", "text"], "default": "markdown", "description": "Content extraction format"},
          "maxChars": {"type": "number", "description": "Maximum characters to return (truncates beyond this)"}
        },
        "required": ["url"]
      },
      "approval_tier": "auto-approve",
      "timeout": 60,
      "rate_limit": 100,
      "network_policy": null
    },
    "message": {
      "persistent": false,
      "docker_image": "comms",
      "command_template": "python /project/scripts/message.py",
      "parameter_schema": {
        "type": "object",
        "properties": {
          "to": {"type": "string", "description": "Recipient address"},
          "subject": {"type": "string", "description": "Message subject"},
          "body": {"type": "string", "description": "Message body"},
          "channel": {"type": "string", "description": "Message channel (email, slack, etc.)"}
        },
        "required": ["to", "body"]
      },
      "approval_tier": "human-confirm",
      "timeout": 30,
      "rate_limit": 20,
      "secret_refs": ["SMTP_PASSWORD"]
    },
    "sessions_send": {
      "persistent": false,
      "docker_image": "comms",
      "command_template": "python /project/scripts/sessions_send.py",
      "parameter_schema": {
        "type": "object",
        "properties": {
          "session_key": {"type": "string", "description": "Target session key"},
          "message": {"type": "string", "description": "Message to send"}
        },
        "required": ["session_key", "message"]
      },
      "approval_tier": "human-confirm",
      "timeout": 30,
      "rate_limit": 50
    },
    "cron": {
      "persistent": false,
      "docker_image": "sandbox",
      "command_template": "python /project/scripts/cron.py",
      "parameter_schema": {
        "type": "object",
        "properties": {
          "schedule": {"type": "string", "description": "Cron expression"},
          "command": {"type": "string", "description": "Command to schedule"},
          "action": {"type": "string", "enum": ["create", "list", "delete"]},
          "jobId": {"type": "string", "description": "Job identifier (line number) for targeted delete"}
        },
        "required": ["action"]
      },
      "approval_tier": "human-confirm",
      "timeout": 30,
      "rate_limit": 10
    },
    "image": {
      "persistent": false,
      "docker_image": "sandbox",
      "command_template": "python /project/scripts/image.py",
      "parameter_schema": {
        "type": "object",
        "properties": {
          "prompt": {"type": "string", "description": "What to analyze in the image(s) (default: Describe the image.)"},
          "image": {"type": "string", "description": "Image path (relative to workspace), URL, or data: URL"},
          "images": {"type": "array", "items": {"type": "string"}, "description": "Multiple images to analyze (max 20)"}
        }
      },
      "approval_tier": "auto-approve",
      "secret_refs": ["VISION_API_KEY"],
      "timeout": 120,
      "rate_limit": 50,
      "network_policy": null
    },
    "tts": {
      "persistent": false,
      "docker_image": "sandbox",
      "command_template": "python /project/scripts/tts.py",
      "parameter_schema": {
        "type": "object",
        "properties": {
          "text": {"type": "string", "description": "Text to synthesize"},
          "voice": {"type": "string", "description": "Voice identifier"}
        },
        "required": ["text"]
      },
      "approval_tier": "auto-approve",
      "timeout": 60,
      "rate_limit": 50
    },
    "canvas": {
      "persistent": false,
      "docker_image": "sandbox",
      "command_template": "python /project/scripts/canvas.py",
      "parameter_schema": {
        "type": "object",
        "properties": {
          "action": {"type": "string", "description": "Canvas action"},
          "content": {"type": "string", "description": "Canvas content"}
        },
        "required": ["action"]
      },
      "approval_tier": "auto-approve",
      "timeout": 30,
      "rate_limit": 100
    },
    "nodes": {
      "persistent": false,
      "docker_image": "sandbox",
      "command_template": "python /project/scripts/nodes.py",
      "parameter_schema": {
        "type": "object",
        "properties": {
          "action": {"type": "string", "description": "Node graph action"},
          "node_id": {"type": "string", "description": "Target node ID"}
        },
        "required": ["action"]
      },
      "approval_tier": "auto-approve",
      "timeout": 30,
      "rate_limit": 100
    },
    "gateway": {
      "approval_tier": "always-deny"
    }
  },
  "images": {
    "sandbox": "validance-sandbox:latest",
    "comms": "validance-comms:latest",
    "web": "validance-web:latest",
    "browser": "validance-browser:latest"
  }
}

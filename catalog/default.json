          "y": {"type": "number", "description": "Canvas Y position"},
          "width": {"type": "number", "description": "Canvas width in pixels"},
          "height": {"type": "number", "description": "Canvas height in pixels"},
          "javaScript": {"type": "string", "description": "JavaScript code to evaluate (eval action)"},
          "outputFormat": {"type": "string", "enum": ["png", "jpg", "jpeg"], "description": "Snapshot image format (default: png)"},
          "maxWidth": {"type": "number", "description": "Maximum snapshot width in pixels"},
          "quality": {"type": "number", "description": "JPEG quality (0-100)"},
          "delayMs": {"type": "number", "description": "Delay before snapshot in milliseconds"},
          "jsonl": {"type": "string", "description": "JSONL content for A2UI push"},
          "jsonlPath": {"type": "string", "description": "Path to JSONL file for A2UI push"},
          "timeoutMs": {"type": "number", "description": "Gateway request timeout in milliseconds"}
        },
        "required": ["action"]
      },
      "approval_tier": "human-confirm",
      "timeout": 60,
      "rate_limit": 30
    },
    "nodes": {
      "description": "Interact with paired devices (nodes): camera, photos, screen recording, location, notifications, and remote commands.",
      "action_hints": {
        "Pairing": "status, describe, pending, approve, reject",
        "Notifications": "notify, notifications_list, notifications_action",
        "Camera & Media": "camera_snap, camera_list, camera_clip, photos_latest, screen_record",
        "Location": "location_get",
        "Device Info": "device_status, device_info, device_permissions, device_health",
        "Execution": "run, invoke"
      },
      "persistent": false,
      "docker_image": "comms",
      "command_template": "python /project/scripts/nodes.py",
      "parameter_schema": {
        "type": "object",
        "properties": {
          "action": {"type": "string", "enum": ["status", "describe", "pending", "approve", "reject", "notify", "camera_snap", "camera_list", "camera_clip", "photos_latest", "screen_record", "location_get", "notifications_list", "notifications_action", "device_status", "device_info", "device_permissions", "device_health", "run", "invoke"], "description": "Node action to perform"},
          "node": {"type": "string", "description": "Node identifier or query string"},

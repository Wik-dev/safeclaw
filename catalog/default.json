{
  "templates": {
    "exec": {
      "description": "Execute shell commands in a sandboxed container with optional background mode.",
      "persistent": true,
      "docker_image": "sandbox",
      "command_template": "python /project/scripts/exec.py",
      "parameter_schema": {
        "type": "object",
        "properties": {
          "command": {"type": "string", "description": "Shell command to execute"},
          "cwd": {"type": "string", "description": "Working directory (relative to /workspace)"},
          "env": {"type": "object", "description": "Environment variables to set"},
          "timeout": {"type": "number", "description": "Timeout in seconds"},
          "background": {"type": "boolean", "description": "Run in background, return session ID immediately"}
        },
        "required": ["command"]
      },
      "approval_tier": "human-confirm",
      "timeout": 120,
      "rate_limit": 200,
      "network_policy": null,
      "workspace_access": true
    },
    "write": {
      "description": "Write content to a file in the workspace.",
      "persistent": true,
      "docker_image": "sandbox",
      "command_template": "python /project/scripts/write_file.py",
      "parameter_schema": {
        "type": "object",
        "properties": {
          "path": {"type": "string", "description": "File path relative to workspace"},
          "content": {"type": "string", "description": "File content to write"}
        },
        "required": ["path", "content"]
      },
      "approval_tier": "auto-approve",
      "timeout": 30,
      "rate_limit": 500,
      "workspace_access": true
    },
    "edit": {
      "description": "Find and replace text in a workspace file.",
      "persistent": true,
      "docker_image": "sandbox",
      "command_template": "python /project/scripts/edit_file.py",
      "parameter_schema": {
        "type": "object",
        "properties": {
          "path": {"type": "string", "description": "File path relative to workspace"},
          "old_string": {"type": "string", "description": "Text to find"},
          "new_string": {"type": "string", "description": "Text to replace with"}
        },
        "required": ["path", "old_string", "new_string"]
      },
      "approval_tier": "auto-approve",
      "timeout": 30,
      "rate_limit": 500,
      "workspace_access": true
    },
    "apply_patch": {
      "description": "Apply a multi-file patch using Begin Patch / End Patch format.",
      "persistent": true,
      "docker_image": "sandbox",
      "command_template": "python /project/scripts/apply_patch.py",
      "parameter_schema": {
        "type": "object",
        "properties": {
          "input": {"type": "string", "description": "Patch content using *** Begin Patch / *** End Patch format"}
        },
        "required": ["input"]
      },
      "approval_tier": "auto-approve",
      "timeout": 30,
      "rate_limit": 500,
      "workspace_access": true
    },
    "browser": {
      "description": "Control a headless Chromium browser with persistent session. Navigate, interact, screenshot, and extract content from web pages.",
      "action_hints": {
        "Navigation": "navigate, snapshot, read_text, wait",
        "Interaction": "click, type, hover, press, select, scroll, submit_form, upload, dialog",
        "Inspection": "screenshot, evaluate, console, pdf",
        "Tabs": "tabs, open, close, focus"
      },
      "persistent": true,
      "docker_image": "browser",
      "command_template": "python /project/scripts/browser.py",
      "parameter_schema": {
        "type": "object",
        "properties": {
          "action": {"type": "string", "enum": ["snapshot", "navigate", "click", "type", "hover", "press", "select", "scroll", "screenshot", "evaluate", "console", "wait", "tabs", "open", "close", "focus", "pdf", "dialog", "upload", "submit_form", "read_text"]},
          "url": {"type": "string", "description": "URL for navigate/open"},
          "ref": {"type": "string", "description": "Element ref from snapshot (e.g. e1, e2)"},
          "selector": {"type": "string", "description": "CSS selector (alternative to ref)"},
          "text": {"type": "string", "description": "Text to type or wait for"},
          "key": {"type": "string", "description": "Keyboard key (e.g. Enter, Tab, ArrowDown)"},
          "script": {"type": "string", "description": "JavaScript to evaluate"},
          "direction": {"type": "string", "enum": ["up", "down"], "description": "Scroll direction"},
          "fullPage": {"type": "boolean", "description": "Full page screenshot"},
          "interactive": {"type": "boolean", "description": "Snapshot interactive elements only"},
          "depth": {"type": "number", "description": "Max snapshot tree depth"},
          "maxChars": {"type": "number", "description": "Max snapshot text length"},
          "index": {"type": "number", "description": "Tab index for focus/close"},
          "accept": {"type": "boolean", "description": "Accept or dismiss dialog"},
          "values": {"type": "array", "items": {"type": "string"}, "description": "Values for select dropdown"},
          "paths": {"type": "array", "items": {"type": "string"}, "description": "File paths for upload"},
          "submit": {"type": "boolean", "description": "Press Enter after typing"},
          "button": {"type": "string", "enum": ["left", "right", "middle"], "description": "Mouse button for click (default: left)"},
          "doubleClick": {"type": "boolean", "description": "Double-click instead of single click"},
          "promptText": {"type": "string", "description": "Text to enter in a prompt dialog before accepting"},
          "textGone": {"type": "string", "description": "Wait until this text disappears from the page"},
          "fn": {"type": "string", "description": "JavaScript function to evaluate (alias for script)"},
          "type": {"type": "string", "enum": ["png", "jpeg"], "description": "Screenshot image format (default: png)"},
          "level": {"type": "string", "description": "Filter console messages by level (log, warn, error)"},
          "timeMs": {"type": "number", "description": "Milliseconds to wait"},
          "timeoutMs": {"type": "number", "description": "Action timeout in ms"},
          "loadState": {"type": "string", "description": "Wait for page state (load, domcontentloaded, networkidle)"},
          "subtype": {"type": "string", "description": "For policy ceiling checks"}
        },
        "required": ["action"]
      },
      "approval_tier": "human-confirm",
      "timeout": 3600,
      "rate_limit": 30,
      "workspace_access": true,
      "policy_ceilings": ["evaluate", "execute_js", "submit_form"]
    },
    "web_search": {
      "description": "Search the web using Brave Search API with filtering by country, language, and date.",
      "persistent": false,
      "docker_image": "web",
      "command_template": "python /project/scripts/web_search.py",
      "parameter_schema": {
        "type": "object",
        "properties": {
          "query": {"type": "string", "description": "Search query"},
          "count": {"type": "number", "description": "Number of results (1-10, default 5)"},
          "country": {"type": "string", "description": "2-letter country code (e.g. US, DE, FR)"},
          "language": {"type": "string", "description": "Language code (e.g. en, fr, de)"},
          "freshness": {"type": "string", "description": "Recency filter (d1=past day, w1=past week, m1=past month, y1=past year)"},
          "date_after": {"type": "string", "description": "Only results after this date (YYYY-MM-DD)"},
          "date_before": {"type": "string", "description": "Only results before this date (YYYY-MM-DD)"}
        },
        "required": ["query"]
      },
      "approval_tier": "auto-approve",
      "secret_refs": ["SEARCH_API_KEY"],
      "timeout": 30,
      "rate_limit": 100,
      "network_policy": {"egress_allow": ["api.search.brave.com:443"]}
    },
    "web_fetch": {
      "description": "Fetch a URL and extract content as markdown or plain text.",
      "persistent": false,
      "docker_image": "web",
      "command_template": "python /project/scripts/web_fetch.py",
      "parameter_schema": {
        "type": "object",
        "properties": {
          "url": {"type": "string", "description": "URL to fetch"},
          "method": {"type": "string", "enum": ["GET", "POST"], "default": "GET"},
          "headers": {"type": "object", "description": "HTTP headers"},
          "body": {"type": "string", "description": "Request body"},
          "extractMode": {"type": "string", "enum": ["markdown", "text"], "default": "markdown", "description": "Content extraction format"},
          "maxChars": {"type": "number", "description": "Maximum characters to return (truncates beyond this)"}
        },
        "required": ["url"]
      },
      "approval_tier": "auto-approve",
      "timeout": 60,
      "rate_limit": 100,
      "network_policy": null
    },
    "message": {
      "description": "Send and manage messages across channels (email, Telegram, Discord, Slack, Signal). Supports send/reply, polls, reactions, threads, stickers, moderation, and channel management.",
      "action_hints": {
        "Messaging": "send, reply, edit, unsend, delete, sendWithEffect, sendAttachment, broadcast",
        "Reactions & Pins": "react, reactions, pin, unpin, list-pins",
        "Polls": "poll, poll-vote",
        "Threads": "thread-create, thread-list, thread-reply",
        "Search & Fetch": "read, search, download-file",
        "Groups": "renameGroup, setGroupIcon, addParticipant, removeParticipant, leaveGroup",
        "Stickers & Emoji": "sticker, sticker-search, sticker-upload, emoji-list, emoji-upload",
        "Channels": "channel-info, channel-list, channel-create, channel-edit, channel-delete, channel-move, category-create, category-edit, category-delete, topic-create",
        "Moderation": "permissions, timeout, kick, ban, member-info, role-info, role-add, role-remove",
        "Events": "event-list, event-create, voice-status",
        "Presence": "set-presence"
      },
      "persistent": false,
      "docker_image": "comms",
      "command_template": "python /project/scripts/message.py",
      "parameter_schema": {
        "type": "object",
        "properties": {
          "action": {"type": "string", "enum": ["send", "broadcast", "poll", "poll-vote", "react", "reactions", "read", "edit", "unsend", "reply", "sendWithEffect", "renameGroup", "setGroupIcon", "addParticipant", "removeParticipant", "leaveGroup", "sendAttachment", "delete", "pin", "unpin", "list-pins", "permissions", "thread-create", "thread-list", "thread-reply", "search", "sticker", "sticker-search", "member-info", "role-info", "emoji-list", "emoji-upload", "sticker-upload", "role-add", "role-remove", "channel-info", "channel-list", "channel-create", "channel-edit", "channel-delete", "channel-move", "category-create", "category-edit", "category-delete", "topic-create", "voice-status", "event-list", "event-create", "timeout", "kick", "ban", "set-presence", "download-file"], "description": "Message action to perform (default: send)"},
          "channel": {"type": "string", "description": "Channel provider (email, telegram, discord, slack, signal, etc.)"},
          "target": {"type": "string", "description": "Recipient — channel/user ID or name"},
          "targets": {"type": "array", "items": {"type": "string"}, "description": "Multiple recipients for broadcast"},
          "message": {"type": "string", "description": "Message text content"},
          "subject": {"type": "string", "description": "Message subject (email)"},
          "media": {"type": "string", "description": "Media URL or local file path to attach"},
          "buffer": {"type": "string", "description": "Base64-encoded attachment payload or data: URL"},
          "filename": {"type": "string", "description": "Attachment filename"},
          "contentType": {"type": "string", "description": "Attachment MIME type"},
          "mimeType": {"type": "string", "description": "Media MIME type (alias for contentType)"},
          "caption": {"type": "string", "description": "Caption for media attachment"},
          "path": {"type": "string", "description": "File path for attachment or download"},
          "filePath": {"type": "string", "description": "Local file path to attach"},
          "replyTo": {"type": "string", "description": "Message ID to reply to"},
          "threadId": {"type": "string", "description": "Thread ID for threaded replies"},
          "emoji": {"type": "string", "description": "Reaction emoji (for react action)"},
          "messageId": {"type": "string", "description": "Target message ID (for react, delete, edit, pin)"},
          "message_id": {"type": "string", "description": "Target message ID (snake_case alias)"},
          "remove": {"type": "boolean", "description": "Remove reaction instead of adding"},
          "asVoice": {"type": "boolean", "description": "Send audio as voice message"},
          "silent": {"type": "boolean", "description": "Send without notification"},
          "buttons": {"type": "array", "description": "Inline keyboard buttons (array of button rows)"},
          "card": {"type": "object", "description": "Adaptive Card JSON object"},
          "components": {"type": "object", "description": "Discord components v2 payload"},
          "effectId": {"type": "string", "description": "Message effect ID (invisible-ink, balloons, etc.)"},
          "effect": {"type": "string", "description": "Message effect name"},
          "quoteText": {"type": "string", "description": "Quoted text in reply"},
          "bestEffort": {"type": "boolean", "description": "Best-effort delivery (skip failures in broadcast)"},
          "gifPlayback": {"type": "boolean", "description": "Enable GIF playback in message"},
          "targetAuthor": {"type": "string", "description": "Target message author for reactions"},
          "targetAuthorUuid": {"type": "string", "description": "Target message author UUID for reactions"},
          "groupId": {"type": "string", "description": "Group/chat ID for group-scoped actions"},
          "pollQuestion": {"type": "string", "description": "Poll question text"},
          "pollOption": {"type": "array", "items": {"type": "string"}, "description": "Poll answer options (min 2)"},
          "pollDurationHours": {"type": "number", "description": "Poll duration in hours"},
          "pollMulti": {"type": "boolean", "description": "Allow multiple poll answers"},
          "pollId": {"type": "string", "description": "Poll ID (for poll-vote)"},
          "pollOptionId": {"type": "string", "description": "Poll option ID to vote for"},
          "pollOptionIds": {"type": "array", "items": {"type": "string"}, "description": "Multiple poll option IDs to vote for"},
          "pollOptionIndex": {"type": "number", "description": "Poll option index to vote for"},
          "pollOptionIndexes": {"type": "array", "items": {"type": "number"}, "description": "Multiple poll option indexes to vote for"},
          "pollDurationSeconds": {"type": "number", "description": "Poll duration in seconds"},
          "pollAnonymous": {"type": "boolean", "description": "Anonymous poll voting"},
          "pollPublic": {"type": "boolean", "description": "Public poll results"},
          "channelId": {"type": "string", "description": "Channel ID for channel-scoped actions"},
          "channelIds": {"type": "array", "items": {"type": "string"}, "description": "Multiple channel IDs"},
          "guildId": {"type": "string", "description": "Guild/server ID (Discord)"},
          "userId": {"type": "string", "description": "User ID filter"},
          "authorId": {"type": "string", "description": "Message author ID filter"},
          "authorIds": {"type": "array", "items": {"type": "string"}, "description": "Multiple author ID filters"},
          "roleId": {"type": "string", "description": "Role ID for role actions"},
          "roleIds": {"type": "array", "items": {"type": "string"}, "description": "Multiple role IDs"},
          "participant": {"type": "string", "description": "Participant identifier for group actions"},
          "emojiName": {"type": "string", "description": "Custom emoji name"},
          "stickerId": {"type": "array", "items": {"type": "string"}, "description": "Sticker ID(s)"},
          "stickerName": {"type": "string", "description": "Sticker name"},
          "stickerDesc": {"type": "string", "description": "Sticker description"},
          "stickerTags": {"type": "string", "description": "Sticker tags (comma-separated)"},
          "threadName": {"type": "string", "description": "Thread name for thread-create"},
          "autoArchiveMin": {"type": "number", "description": "Thread auto-archive duration in minutes"},
          "appliedTags": {"type": "array", "items": {"type": "string"}, "description": "Forum tags to apply to thread"},
          "query": {"type": "string", "description": "Search query (for search action)"},
          "eventName": {"type": "string", "description": "Event name for event-create"},
          "eventType": {"type": "string", "description": "Event type"},
          "startTime": {"type": "string", "description": "Event start time (ISO 8601)"},
          "endTime": {"type": "string", "description": "Event end time (ISO 8601)"},
          "desc": {"type": "string", "description": "Event description"},
          "location": {"type": "string", "description": "Event location"},
          "durationMin": {"type": "number", "description": "Event duration in minutes"},
          "until": {"type": "string", "description": "Recurring event end date"},
          "reason": {"type": "string", "description": "Moderation reason (for kick, ban, timeout)"},
          "deleteDays": {"type": "number", "description": "Days of messages to delete on ban (0-7)"},
          "name": {"type": "string", "description": "Channel/category name for create/edit"},
          "type": {"type": "number", "description": "Channel type (Discord channel type number)"},
          "parentId": {"type": "string", "description": "Parent category ID for channel create/move"},
          "topic": {"type": "string", "description": "Channel topic"},
          "position": {"type": "number", "description": "Channel position in list"},
          "nsfw": {"type": "boolean", "description": "Mark channel as NSFW"},
          "rateLimitPerUser": {"type": "number", "description": "Slowmode delay in seconds"},
          "categoryId": {"type": "string", "description": "Category ID for channel move"},
          "clearParent": {"type": "boolean", "description": "Remove channel from category"},
          "activityType": {"type": "string", "description": "Presence activity type (playing, streaming, listening, watching, competing)"},
          "activityName": {"type": "string", "description": "Presence activity name"},
          "activityUrl": {"type": "string", "description": "Presence activity URL (for streaming)"},
          "activityState": {"type": "string", "description": "Presence custom status text"},
          "status": {"type": "string", "description": "Presence status (online, idle, dnd, invisible)"},
          "accountId": {"type": "string", "description": "Account ID for multi-account channels"},
          "dryRun": {"type": "boolean", "description": "Validate without sending"},
          "limit": {"type": "number", "description": "Message fetch limit (for read action)"},
          "before": {"type": "string", "description": "Fetch messages before this ID"},
          "after": {"type": "string", "description": "Fetch messages after this ID"},
          "around": {"type": "string", "description": "Fetch messages around this ID"},
          "fromMe": {"type": "boolean", "description": "Filter to messages from self"},
          "includeArchived": {"type": "boolean", "description": "Include archived channels/threads"},
          "timeoutMs": {"type": "number", "description": "Gateway request timeout in milliseconds"}
        },
        "required": ["message"]
      },
      "approval_tier": "human-confirm",
      "timeout": 30,
      "rate_limit": 20,
      "secret_refs": []
    },
    "sessions_send": {
      "description": "Send a message to an active session and optionally wait for a response.",
      "persistent": false,
      "docker_image": "comms",
      "command_template": "python /project/scripts/sessions_send.py",
      "parameter_schema": {
        "type": "object",
        "properties": {
          "session_key": {"type": "string", "description": "Target session key"},
          "message": {"type": "string", "description": "Message to send"},
          "label": {"type": "string", "description": "Display label for the session"},
          "agentId": {"type": "string", "description": "Agent identifier for the message"},
          "timeoutSeconds": {"type": "number", "description": "Response timeout in seconds (default: 10)"}
        },
        "required": ["session_key", "message"]
      },
      "approval_tier": "human-confirm",
      "timeout": 30,
      "rate_limit": 50
    },
    "cron": {
      "description": "Schedule, list, update, and manage recurring cron jobs.",
      "persistent": true,
      "docker_image": "sandbox",
      "command_template": "python /project/scripts/cron.py",
      "parameter_schema": {
        "type": "object",
        "properties": {
          "action": {"type": "string", "enum": ["create", "list", "delete", "update", "run", "runs"], "description": "Cron action"},
          "schedule": {"type": "string", "description": "Cron expression (e.g. */5 * * * *)"},
          "command": {"type": "string", "description": "Command to schedule"},
          "jobId": {"type": "string", "description": "Job identifier (UUID)"},
          "name": {"type": "string", "description": "Optional human-readable label for the job"},
          "enabled": {"type": "boolean", "description": "Enable or disable the job (for update)"},
          "limit": {"type": "number", "description": "Max entries to return (for runs, default 20)"},
          "status": {"type": "string", "description": "Filter runs by status (ok or error)"}
        },
        "required": ["action"]
      },
      "approval_tier": "human-confirm",
      "timeout": 30,
      "rate_limit": 10
    },
    "process": {
      "description": "Manage background processes: list, poll status, view logs, kill, or remove.",
      "persistent": true,
      "docker_image": "sandbox",
      "command_template": "python /project/scripts/process.py",
      "parameter_schema": {
        "type": "object",
        "properties": {
          "action": {"type": "string", "enum": ["list", "poll", "log", "kill", "remove"], "description": "Process management action"},
          "sessionId": {"type": "string", "description": "Background session identifier"},
          "offset": {"type": "number", "description": "Byte offset for log pagination"},
          "limit": {"type": "number", "description": "Max bytes to return for log (default 50000)"}
        },
        "required": ["action"]
      },
      "approval_tier": "auto-approve",
      "timeout": 30,
      "rate_limit": 200
    },
    "image": {
      "description": "Analyze images using vision AI. Accepts workspace paths, URLs, or data: URLs.",
      "persistent": true,
      "docker_image": "sandbox",
      "command_template": "python /project/scripts/image.py",
      "parameter_schema": {
        "type": "object",
        "properties": {
          "prompt": {"type": "string", "description": "What to analyze in the image(s) (default: Describe the image.)"},
          "image": {"type": "string", "description": "Image path (relative to workspace), URL, or data: URL"},
          "images": {"type": "array", "items": {"type": "string"}, "description": "Multiple images to analyze (max 20)"},
          "maxTokens": {"type": "number", "description": "Maximum tokens in the analysis response (default: 4096)"}
        }
      },
      "approval_tier": "auto-approve",
      "secret_refs": ["VISION_API_KEY"],
      "timeout": 120,
      "rate_limit": 50,
      "network_policy": null
    },
    "tts": {
      "description": "Convert text to speech audio using a configurable voice.",
      "persistent": true,
      "docker_image": "sandbox",
      "command_template": "python /project/scripts/tts.py",
      "parameter_schema": {
        "type": "object",
        "properties": {
          "text": {"type": "string", "description": "Text to synthesize"},
          "voice": {"type": "string", "description": "Voice identifier"},
          "channel": {"type": "string", "description": "Output channel (default: file)"}
        },
        "required": ["text"]
      },
      "approval_tier": "auto-approve",
      "secret_refs": ["TTS_API_KEY"],
      "timeout": 60,
      "rate_limit": 50
    },
    "canvas": {
      "description": "Present web content in the UI canvas, navigate, evaluate JavaScript, and take snapshots.",
      "persistent": false,
      "docker_image": "comms",
      "command_template": "python /project/scripts/canvas.py",
      "parameter_schema": {
        "type": "object",
        "properties": {
          "action": {"type": "string", "enum": ["present", "hide", "navigate", "eval", "snapshot", "a2ui_push", "a2ui_reset"], "description": "Canvas action to perform"},

          "duration": {"type": "string", "description": "Video duration string (e.g. 5s)"},
          "durationMs": {"type": "number", "description": "Video duration in milliseconds (max 300000)"},
          "includeAudio": {"type": "boolean", "description": "Include audio in video recording"},
          "fps": {"type": "number", "description": "Screen recording frame rate"},
          "screenIndex": {"type": "number", "description": "Screen index for recording (0-based)"},
          "outPath": {"type": "string", "description": "Output file path for recording"},
          "maxAgeMs": {"type": "number", "description": "Maximum age of cached location in ms"},
          "locationTimeoutMs": {"type": "number", "description": "Location query timeout in ms"},
          "desiredAccuracy": {"type": "string", "enum": ["coarse", "balanced", "precise"], "description": "Location accuracy level"},
          "notificationAction": {"type": "string", "enum": ["open", "dismiss", "reply"], "description": "Notification action to perform"},
          "notificationKey": {"type": "string", "description": "Notification identifier"},

          "facing": {"type": "string", "enum": ["front", "back", "both"], "description": "Camera facing direction"},
          "maxWidth": {"type": "number", "description": "Maximum image width in pixels"},
          "quality": {"type": "number", "description": "Image quality (0-1)"},
          "delayMs": {"type": "number", "description": "Delay before capture in milliseconds"},
          "deviceId": {"type": "string", "description": "Specific camera device ID"},
